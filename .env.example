# PedalBot v3 — environment variables
# Copy this file to `.env.local` and fill in real values. `.env.local` is
# gitignored. All inference runs through Nemotron on GMI Cloud (no OpenAI or
# Anthropic key needed); ScrapeCreators provides live Marketplace search data.

# --- GMI Cloud Model Hub (OpenAI-compatible Nemotron API) -------------------
# Used by app/api/chat/route.ts. If GMI_API_KEY/GMI_API_BASE_URL are unset, the
# chat route falls back to deterministic stub responses so local dev still runs.
GMI_API_BASE_URL=https://api.gmi-serving.com
GMI_API_KEY=your-gmi-api-key
GMI_MODEL=nvidia/nemotron-3-ultra-550b-a55b

# --- ScrapeCreators (live Facebook Marketplace data provider) ---------------
# Used by app/api/marketplace/{search,item,location}/route.ts.
# Without this key the marketplace routes return 503 and the search agent falls
# back to seeded listings (lib/data.ts).
SCRAPECREATORS_API_KEY=your-scrapecreators-api-key

# ===========================================================================
# RunPod backend (runpod/) — BrightData scraping + Qwen2.5-VL defect detection
# ===========================================================================

# --- RunPod (serverless GPU/CPU host for the flash endpoints) ---------------
# Used by `flash dev` / `flash deploy`. Alternatively run `flash login` once
# (browser auth) instead of setting this. Required to run the scraper/vision
# endpoints on RunPod; NOT needed for the offline demo (`python -m runpod.demo`).
RUNPOD_API_KEY=your-runpod-api-key

# --- BrightData (live Facebook Marketplace scraping) ------------------------
# Used by runpod/lib/brightdata.py (scraper endpoint). Without BRIGHTDATA_API_TOKEN
# the scraper falls back to seeded iPhone fixtures (runpod/fixtures/), so dev and
# the demo still run keyless.
BRIGHTDATA_API_TOKEN=your-brightdata-api-token
# The Facebook-Marketplace scraper dataset id from your BrightData dashboard.
# Defaults to the placeholder "gd_facebook_marketplace" if unset — set the real
# id before making live BrightData calls.
BRIGHTDATA_DATASET_ID=gd_facebook_marketplace
